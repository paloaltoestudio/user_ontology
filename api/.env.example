# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/registration_db
DATABASE_ECHO=false

# API
API_V1_STR=/api/v1
PROJECT_NAME=SaaS Registration Engine
DEBUG=false

# Security
SECRET_KEY=your-super-secret-key-change-in-production-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_MIN_LENGTH=8

# CORS
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true

# External Services
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/
N8N_API_KEY=your-n8n-api-key
