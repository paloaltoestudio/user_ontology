# =============================================================================
# UserVision - Production Environment Template
# Copy to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=uservision
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=uservision_db

# --- FastAPI app ---
# DATABASE_URL is auto-built by docker-compose from the POSTGRES_* vars above.
# Only set this if running the API outside Docker.
# DATABASE_URL=postgresql+asyncpg://uservision:password@localhost:5432/uservision_db

SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin bootstrap key - used once to create the first admin user
ADMIN_SETUP_KEY=CHANGE_ME_unique_setup_key

# CORS - set to your Vercel frontend URL (and any other origins that need access)
# Include the protocol prefix. Comma-separate multiple origins inside the JSON array.
CORS_ORIGINS=["https://YOUR_APP.vercel.app"]
CORS_ALLOW_CREDENTIALS=true

# Optional: n8n integration
N8N_WEBHOOK_URL=
N8N_API_KEY=

# MCP server (integrated into FastAPI on same port 8000)
ENABLE_MCP=true
MCP_PORT=

# Uvicorn workers (default 2; for 1 OCPU use 2, for 4 OCPU use 5)
WORKERS=2

# Application settings
PROJECT_NAME=UserVision
DEBUG=false
DATABASE_ECHO=false
PORT=8000
